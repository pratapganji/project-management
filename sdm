One paragraph summary for QE:

SDM File Export API has 5 export endpoints under /citihawk/schemabrowser. QE can call these endpoints by passing SOEID in the x-citiportal-ssoid header. Based on the endpoint and load parameter, the application exports data from OM_CATALOGUE_SUNDRY, OM_CATALOGUE_SOURCE_SYSTEM, or OM_CATALOGUE_SOURCE_SYSTEM_COVERAGE. For load=7 it performs weekly load, for load=1 it performs specific day load, without load it performs full load, and adhoc endpoints export records based on last successful run from OM_CATALOGUE_SDM_LOG. Each successful API call downloads a ZIP file containing one CSV data file and one .csv.ready control file. The CSV contains exported Oracle table data, the control file contains record count, the SDM log table is updated, and success/failure notification email is triggered.





public class AllowedEmailDomainsListValidatorImpl
        implements ConstraintValidator<AllowedEmailDomainsListValidator, List<String>> {

    private static final Logger logger =
            LoggerFactory.getLogger(AllowedEmailDomainsListValidatorImpl.class);

    @Value("${notification.email.validDomains}")
    private Set<String> validDomains;

    @Override
    public boolean isValid(List<String> emails, ConstraintValidatorContext context) {
        if (emails == null || emails.isEmpty()) {
            return true;
        }

        for (String email : emails) {
            if (email == null || email.isBlank()) {
                return false;
            }

            if (!email.contains("@")) {
                return false;
            }

            String domain = email.substring(email.indexOf("@") + 1);

            if (!validDomains.contains("@" + domain)) {
                logger.error("Domain '{}' is not allowed", domain);
                return false;
            }
        }

        return true;
    }
}








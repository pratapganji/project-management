SET PAGESIZE 200
SET LINESIZE 200
SET FEEDBACK ON
SET HEADING ON

SELECT a.constraint_name,
       a.table_name child_table,
       c_pk.table_name parent_table
FROM   all_constraints a
JOIN   all_constraints c_pk
ON     a.r_constraint_name = c_pk.constraint_name
WHERE  a.constraint_name = 'FK_OM_JOB_MASTER_INS_STREAM'
AND    a.owner = 'C167969OMC';

SELECT acc.constraint_name, acc.table_name, acc.column_name, acc.position
FROM   all_cons_columns acc
WHERE  acc.owner='C167969OMC'
AND    acc.constraint_name='FK_OM_JOB_MASTER_INS_STREAM'
ORDER BY acc.position;
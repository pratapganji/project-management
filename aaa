SELECT ROLE_NAME
FROM A167969NURAREC.FID_ROLE
WHERE FID_NAME = 'OLYMPUS_FID';


SELECT ROLE_NAME,
       TABLE_NAME,
       PERMISSION
FROM A167969NURAREC.ROLE_TABLE_PERMISSION
WHERE ROLE_NAME IN (
    SELECT ROLE_NAME
    FROM A167969NURAREC.FID_ROLE
    WHERE FID_NAME = 'OLYMPUS_FID'
);


SELECT ROLE_NAME,
       TABLE_NAME,
       COLUMN_NAME,
       PERMISSION
FROM A167969NURAREC.ROLE_COLUMN_PERMISSION
WHERE ROLE_NAME IN (
    SELECT ROLE_NAME
    FROM A167969NURAREC.FID_ROLE
    WHERE FID_NAME = 'OLYMPUS_FID'
);


SELECT
    f.FID_NAME,
    f.ROLE_NAME,
    t.TABLE_NAME,
    t.PERMISSION,
    c.COLUMN_NAME
FROM A167969NURAREC.FID_ROLE f
LEFT JOIN A167969NURAREC.ROLE_TABLE_PERMISSION t
       ON f.ROLE_NAME = t.ROLE_NAME
LEFT JOIN A167969NURAREC.ROLE_COLUMN_PERMISSION c
       ON f.ROLE_NAME = c.ROLE_NAME
WHERE f.FID_NAME = 'OLYMPUS_FID';


SELECT *
FROM A167969NURAREC.FID_ROLE
WHERE FID_NAME = 'OLYMPUS_FID';